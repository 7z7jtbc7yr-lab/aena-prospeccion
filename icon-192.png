import { StrictMode } from 'react'
import { createRoot } from 'react-dom/client'
import App from './App.jsx'

window.storage = {
  get: async (key) => {
    try {
      const val = localStorage.getItem('aena_' + key)
      return val ? { key, value: val } : null
    } catch { return null }
  },
  set: async (key, value) => {
    try {
      localStorage.setItem('aena_' + key, value)
      return { key, value }
    } catch { return null }
  },
  delete: async (key) => {
    try {
      localStorage.removeItem('aena_' + key)
      return { key, deleted: true }
    } catch { return null }
  },
  list: async (prefix) => {
    try {
      const keys = Object.keys(localStorage)
        .filter(k => k.startsWith('aena_' + (prefix || '')))
        .map(k => k.replace('aena_', ''))
      return { keys }
    } catch { return { keys: [] } }
  }
}

createRoot(document.getElementById('root')).render(
  <StrictMode>
    <App />
  </StrictMode>
)
